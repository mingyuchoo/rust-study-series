# Rust build outputs
/target/
/dist/

# This is an executable app, so keep the lockfile reproducible.
!/Cargo.lock

# Rust backup files generated by rustfmt/cargo tooling
**/*.rs.bk

# Local environment overrides
.env
.env.*
!.env.example

# Logs
*.log

# Editors and IDEs
/.vscode/
/.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
