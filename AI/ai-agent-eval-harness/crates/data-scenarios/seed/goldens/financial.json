{
  "domain": "financial",
  "version": "1.0",
  "golden_sets": [
    {
      "scenario_id": "fin_001",
      "input": {
        "task": "단리 이자 계산",
        "environment": {
          "customer_id": "C001",
          "deposit_amount": 1000000,
          "interest_rate": 0.05,
          "period_years": 2,
          "calculation_method": "simple"
        }
      },
      "expected_output": {
        "tool_sequence": ["financial__calculate_simple_interest"],
        "tool_results": {
          "interest": 100000.0,
          "total_amount": 1100000.0
        },
        "tolerance": 0.01,
        "expected_domain": "financial"
      }
    },
    {
      "scenario_id": "fin_002",
      "input": {
        "task": "복리 이자 계산 및 단리 비교",
        "environment": {
          "customer_id": "C002",
          "deposit_amount": 1000000,
          "interest_rate": 0.05,
          "period_years": 2,
          "compounds_per_year": 12
        }
      },
      "expected_output": {
        "tool_sequence": ["financial__calculate_compound_interest", "financial__calculate_simple_interest"],
        "tool_results": {
          "compound_better_than_simple": true
        },
        "tolerance": 0.01,
        "expected_domain": "financial"
      }
    },
    {
      "scenario_id": "fin_003",
      "input": {
        "task": "대액 출금 검증",
        "environment": {
          "account_id": "A001",
          "account_balance": 5000000,
          "transaction_type": "withdraw",
          "transaction_amount": 4800000
        }
      },
      "expected_output": {
        "tool_sequence": ["financial__validate_transaction"],
        "tool_results": {
          "is_valid": true,
          "has_warnings": true
        },
        "tolerance": 0.01,
        "expected_domain": "financial"
      }
    },
    {
      "scenario_id": "fin_004",
      "input": {
        "task": "예금 데이터 파일 분석",
        "environment": {
          "input_file": "deposit_data.json",
          "output_file": "result.json"
        }
      },
      "expected_output": {
        "tool_sequence": ["read_file", "financial__calculate_simple_interest", "write_file"],
        "tool_results": {
          "file_created": true,
          "all_customers_processed": true
        },
        "tolerance": 0.01,
        "expected_domain": "financial"
      }
    },
    {
      "scenario_id": "fin_005",
      "input": {
        "task": "종합 금융 분석",
        "environment": {
          "customer_id": "C003",
          "principal": 10000000,
          "period_years": 3,
          "simple_rate": 0.045,
          "compound_rate": 0.043,
          "compounds_per_year": 12
        }
      },
      "expected_output": {
        "tool_sequence": ["financial__calculate_simple_interest", "financial__calculate_compound_interest", "write_file"],
        "tool_results": {
          "comparison_done": true,
          "file_created": true,
          "recommendation_provided": true
        },
        "tolerance": 0.01,
        "expected_domain": "financial"
      }
    }
  ]
}
